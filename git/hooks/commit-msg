#!/bin/sh
# commit-msg hook: reject any commit message paragraph that contains an
# internal line break.
#
# A "paragraph" is a run of consecutive prose lines (non-blank, non-structural).
# If a paragraph has two or more such lines, the second one is an internal
# line break and the message is rejected — regardless of line length or
# whether the continuation starts uppercase or lowercase. This catches both
# the classic 72-char wrap and sentence-per-line layouts.
#
# Skipped (allowed to span multiple lines without flagging):
#   - subject line (line 1)
#   - blank lines
#   - list items (-, *, +, 1.)
#   - blockquotes (>)
#   - headings (#)
#   - tables (|)
#   - indented code (4+ spaces or tab)
#   - fenced code blocks (``` ... ```)
#   - trailers (Foo-Bar: value)
#   - git comment lines (#)
#
# Bypass with: git commit --no-verify
#
# Exit 0 = accept, exit 1 = reject.

set -eu

msgfile="$1"

awk '
function is_structural(line) {
    # Lists, blockquotes, headings, tables, indented code (4+ spaces or tab)
    if (line ~ /^[[:space:]]*([-*+>#|]|[0-9]+\.)/) return 1
    if (line ~ /^(    |\t)/) return 1
    # Conventional trailers: "Word-Word:" or "Word:" followed by space at start
    if (line ~ /^[A-Z][A-Za-z0-9_-]*:[[:space:]]/) return 1
    return 0
}

function is_blank(line) {
    return line ~ /^[[:space:]]*$/
}

{
    lineno++

    # Strip git scissors/comment lines (do not advance paragraph state)
    if (substr($0, 1, 1) == "#") next

    # Toggle fenced code block state; lines inside a fence are exempt
    if ($0 ~ /^```/) {
        in_fence = !in_fence
        in_paragraph = 0
        next
    }
    if (in_fence) { in_paragraph = 0; next }

    # Skip subject line
    if (lineno == 1) { in_paragraph = 0; next }

    # Blank or structural lines end any current paragraph
    if (is_blank($0) || is_structural($0)) {
        in_paragraph = 0
        next
    }

    # Prose line. If we are already inside a paragraph, this is an internal
    # line break and the rule is violated.
    if (in_paragraph) {
        printf "  line %d: %s\n", prev_lineno, prev_line > "/dev/stderr"
        printf "  line %d: %s\n", lineno, $0 > "/dev/stderr"
        printf "\n" > "/dev/stderr"
        fail = 1
    }
    in_paragraph = 1
    prev_line = $0
    prev_lineno = lineno
}
END {
    if (fail) {
        print "commit-msg: rejected — paragraph contains an internal line break." > "/dev/stderr"
        print "Each paragraph must be a single unwrapped line. Line breaks belong only" > "/dev/stderr"
        print "between paragraphs, in lists/quotes/tables, or in trailers." > "/dev/stderr"
        print "Bypass with: git commit --no-verify" > "/dev/stderr"
        exit 1
    }
}
' "$msgfile"
